# ============================================================
# .env.example
# Copy this file to .env and fill in your actual values.
# The .env file is NEVER committed to version control.
#
# Production file lives at: /opt/oah/.env on the EC2 host
# Permissions: chmod 600 /opt/oah/.env
# ============================================================

# ── Django Core ──────────────────────────────────────────────
# Generate a new key with:
#   python -c "import secrets; print(secrets.token_urlsafe(60))"
SECRET_KEY=replace-with-a-long-random-string

DEBUG=False

# Comma-separated list of allowed hostnames (no http://)
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

# ── Database ─────────────────────────────────────────────────
# Set to True in production to use RDS PostgreSQL
USE_RDS=False

# AWS RDS — required only when USE_RDS=True
RDS_DB_HOST=your-instance.xxxxxxxxx.us-east-1.rds.amazonaws.com
RDS_DB_NAME=your_database_name
RDS_DB_USER=your_db_username
RDS_DB_PASSWORD=your_db_password
RDS_DB_PORT=5432
RDS_SSL_MODE=require
DB_CONN_MAX_AGE=60

# ── Media Storage ────────────────────────────────────────────
# Set to True in production to serve media from S3
USE_S3=False

# AWS S3 — required only when USE_S3=True
# Prefer IAM roles on EC2 over long-lived keys
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=us-east-1

# Optional: CloudFront domain (leave blank to use default S3 URL)
AWS_S3_CUSTOM_DOMAIN=

# ── Cache / Sessions ─────────────────────────────────────────
# Set to True in production to use ElastiCache for Redis
USE_CACHE=False

# Redis / ElastiCache connection URL
# Local dev  : redis://127.0.0.1:6379
# ElastiCache: rediss://your-cluster.xxxx.ng.0001.use1.cache.amazonaws.com:6379
REDIS_URL=redis://127.0.0.1:6379

# ── Monitoring (optional) ────────────────────────────────────
# Sentry DSN for automatic error tracking (leave blank to disable)
SENTRY_DSN=